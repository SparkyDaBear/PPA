---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getOntology, getRelease } from '../../lib/site-data';

const [release, ontology] = await Promise.all([getRelease(), getOntology()]);
const base = import.meta.env.BASE_URL;

const treePayload = {
  nodes: ontology.nodes || [],
  branches: ontology.branches || {},
};
---

<BaseLayout title="Ontology Tree · PPA Curator Workbench">
  <section class="hero-panel">
    <div>
      <p class="hero-kicker">Ontology tree</p>
      <h2>Explore branch-first ontology structure with lazy expansion and linked term detail pages.</h2>
    </div>
    <div class="hero-badges">
      <span class="badge">{release.term_count} terms</span>
      <span class="badge">D3 interactive tree</span>
    </div>
  </section>

  <section class="panel">
    <div class="tree-layout">
      <div class="tree-view-wrap" id="tree-view" data-base={base}>
        <svg id="ontology-tree-svg" class="tree-svg" role="img" aria-label="Ontology tree visualization"></svg>
      </div>
      <aside class="tree-detail" id="tree-detail" aria-live="polite">
        <p class="detail-kicker">Node details</p>
        <h3 id="tree-node-title">Select a node</h3>
        <p class="row-meta" id="tree-node-curie">Click any node in the tree to inspect its details.</p>
        <p class="row-meta" id="tree-node-branch"></p>
        <p class="row-meta" id="tree-node-def"></p>
        <p class="row-meta" id="tree-node-stats"></p>
        <p id="tree-node-link-wrap"></p>
      </aside>
    </div>
  </section>

  <script id="ontology-tree-data" type="application/json" set:html={JSON.stringify(treePayload)}></script>
  <script>
    import { initOntologyTree } from '../../scripts/ontology-tree';

    initOntologyTree({
      svgId: 'ontology-tree-svg',
      dataId: 'ontology-tree-data',
      containerId: 'tree-view',
      detailPrefix: 'tree-node',
    });
  </script>
</BaseLayout>

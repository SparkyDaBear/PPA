---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjectIndex, getRelease } from '../../lib/site-data';

const [release, projectIndex] = await Promise.all([getRelease(), getProjectIndex()]);
const projects = projectIndex.projects || [];
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Projects · PPA Curator Workbench">
  <section class="hero-panel">
    <div>
      <p class="hero-kicker">Project browser</p>
      <h2>Browse curated PXD records and open a dedicated detail page for each study.</h2>
    </div>
    <div class="hero-badges">
      <span class="badge">{projects.length} PXDs</span>
      <span class="badge">Detail routes enabled</span>
    </div>
  </section>

  <section class="panel">
    <label class="search-field">
      <span>Search projects</span>
      <input id="project-search" type="search" placeholder="Search PXD, label, scope, or instrument" />
    </label>
    <p id="project-search-status" class="search-status" aria-live="polite"></p>
    <noscript>
      <p class="empty-state">Project filtering requires JavaScript. You can still browse all projects below.</p>
    </noscript>
    <div id="project-results" class="table-list">
      {projects.map((project) => {
        const summary = project.summary || {};
        const labels = [summary.acquisition_type, summary.quantification_method, ...(summary.labeling_strategy || [])].filter(Boolean).join(' · ');
        return (
          <a class="table-row row-clickable project-row" href={`${base}projects/${project.pxd}/`} data-search={`${project.pxd} ${summary.acquisition_type || ''} ${summary.quantification_method || ''} ${summary.sample_scope_label || ''} ${(summary.labeling_strategy || []).join(' ')}`.toLowerCase()}>
            <div class="row-head">
              <h4 class="row-title">{project.pxd}</h4>
              <span class="row-code">{summary.sample_scope_label || 'no scope'}</span>
            </div>
            <div class="row-meta">{labels || 'No summary labels exported yet.'}</div>
            <div class="row-meta">{summary.instrument || 'No instrument exported yet.'}</div>
          </a>
        );
      })}
    </div>
  </section>

  <script>
    import { initListSearch } from '../../scripts/list-search';

    initListSearch({
      inputId: 'project-search',
      rowSelector: '.project-row',
      statusId: 'project-search-status',
      entityPlural: 'projects',
    });
  </script>
</BaseLayout>
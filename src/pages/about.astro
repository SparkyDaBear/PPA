---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getRelease } from '../lib/site-data';

const release = await getRelease();
---

<BaseLayout title="About · PPA Curator Workbench">
  <section class="hero-panel">
    <div>
      <p class="hero-kicker">About</p>
      <h2>How the public site is assembled and what it intentionally does not expose.</h2>
    </div>
    <div class="hero-badges">
      <span class="badge">Release {release.export_version}</span>
      <span class="badge">{release.public_evidence_policy}</span>
    </div>
  </section>

  <section class="panel">
    <SectionHeading kicker="Data model" title="Public export contract" />
    <ul class="detail-list">
      <li>The public site reads the generated JSON bundle from <span class="row-code">export/</span>.</li>
      <li>Detail pages are built statically from the export bundle, not from the private repo.</li>
      <li>Evidence is links-first, with no raw private text exposure by default.</li>
      <li>The visual direction is earthy, minimalist, and optimized for scan-friendly reference browsing.</li>
    </ul>
  </section>
</BaseLayout>
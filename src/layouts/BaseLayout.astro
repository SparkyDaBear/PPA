---
const { title, description = 'Proteomics Perturbation Atlas public explorer' } = Astro.props;
const pathname = Astro.url.pathname;

function navClass(target) {
  return pathname === target ? 'nav-link is-active' : 'nav-link';
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div class="page-shell">
      <aside class="sidebar">
        <div class="brand-block">
          <p class="eyebrow">Proteomics Perturbation Atlas</p>
          <h1>PPA Curator Workbench</h1>
          <p class="lede">
            A public atlas for ontology terms, curated project metadata, and workflow summaries.
          </p>
        </div>

        <nav class="nav-block" aria-label="Primary">
          <a class={navClass('/')} href="/" aria-current={pathname === '/' ? 'page' : undefined}>Overview</a>
          <a class={navClass('/terms/')} href="/terms/" aria-current={pathname === '/terms/' ? 'page' : undefined}>Ontology Terms</a>
          <a class={navClass('/projects/')} href="/projects/" aria-current={pathname === '/projects/' ? 'page' : undefined}>Projects</a>
          <a class={navClass('/about/')} href="/about/" aria-current={pathname === '/about/' ? 'page' : undefined}>About</a>
        </nav>

        <slot name="sidebar" />
      </aside>

      <main class="main-panel">
        <slot />
      </main>
    </div>
  </body>
</html>
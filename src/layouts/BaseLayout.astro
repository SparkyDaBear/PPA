---
import '../styles/global.css';

const { title, description = 'Proteomics Perturbation Atlas public explorer' } = Astro.props;
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;
const relativePath = pathname.startsWith(base)
  ? `/${pathname.slice(base.length)}`
  : pathname;

function navClass(target) {
  return relativePath === target ? 'nav-link is-active' : 'nav-link';
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <aside class="sidebar">
        <div class="brand-block">
          <p class="eyebrow">Proteomics Perturbation Atlas</p>
          <h1>PPA Curator Workbench</h1>
          <p class="lede">
            A public atlas for ontology terms, curated project metadata, and workflow summaries.
          </p>
        </div>

        <nav class="nav-block" aria-label="Primary">
          <a class={navClass('/')} href={base} aria-current={relativePath === '/' ? 'page' : undefined}>Overview</a>
          <a class={navClass('/terms/')} href={`${base}terms/`} aria-current={relativePath === '/terms/' ? 'page' : undefined}>Ontology Terms</a>
          <a class={navClass('/projects/')} href={`${base}projects/`} aria-current={relativePath === '/projects/' ? 'page' : undefined}>Projects</a>
          <a class={navClass('/about/')} href={`${base}about/`} aria-current={relativePath === '/about/' ? 'page' : undefined}>About</a>
        </nav>

        <slot name="sidebar" />
      </aside>

      <main class="main-panel">
        <slot />
      </main>
    </div>
  </body>
</html>
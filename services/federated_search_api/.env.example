# Server
FEDERATED_SEARCH_HOST=0.0.0.0
FEDERATED_SEARCH_PORT=8787
FEDERATED_SEARCH_CORS_ORIGINS=https://sparkydabear.github.io

# PPA local export source (private repo checkout)
PPA_EXPORT_DIR=/storage/group/epo2/default/ims86/git_repos/PerturbationAtlas/public/PPA/export
PPA_EXPORT_BASE_URL=https://raw.githubusercontent.com/sparkydabear/PPA/main/export
PPA_EXPORT_FETCH_TIMEOUT_SECONDS=15

# Optional external sources
ENABLE_PRIDE=true
ENABLE_PROTEOMEXCHANGE=true
# Explicit override. If omitted, MCP auto-enables when MCP_BRIDGE_URL or
# MCP_CHAT_BRIDGE_URL is configured.
# ENABLE_MCP_SOURCE=true

# Optional source-specific credentials
PRIDE_API_KEY=
PROTEOMEXCHANGE_API_KEY=

# Optional MCP bridge endpoint. Keep this server-side.
MCP_BRIDGE_URL=
MCP_BRIDGE_TOKEN=
MCP_CHAT_BRIDGE_URL=
# Example for single-service deployment:
# MCP_CHAT_BRIDGE_URL=https://ppa-gx72.onrender.com/v1/mcp/chat-bridge

# Optional direct model settings (not used by MCP-only chat mode).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
